{
  "name": "cnwla",
  "version": "0.0.1",
  "description": "cnwla — Canton Network Wrapped LedgerAPI. A cast-style CLI for Canton Network's JSON Ledger API v2.",
  "main": "./dist/cli.js",
  "scripts": {
    "test": "node --import tsx --test test/unit/*.test.ts test/integration/*.test.ts",
    "test:unit": "node --import tsx --test test/unit/*.test.ts",
    "test:integration": "node --import tsx --test test/integration/*.test.ts",
    "test:watch": "node --import tsx --test --watch test/unit/*.test.ts",
    "dev": "tsx src/cli.ts",
    "build": "tsc"
  },
  "keywords": [
    "canton",
    "canton-network",
    "daml",
    "ledger",
    "cli",
    "json-ledger-api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "jsonwebtoken": "^9.0.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "bin": {
    "cnwla": "./dist/cli.js"
  },
  "type": "module"
}
